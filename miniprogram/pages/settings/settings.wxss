.module-tabs {
  display: flex;
  gap: 10rpx;
  width: 100%;
  margin-bottom: 24rpx;
  padding: 8rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.module-tabs view {
  display: inline-grid;
  place-items: center;
  min-width: 128rpx;
  min-height: 68rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  color: #5f7895;
  font-weight: 900;
}

.module-tabs .active {
  color: #fff;
  background: linear-gradient(135deg, #38bdf8, #5eead4);
}
