<view class="page">
  <view class="title">统计</view>
  <view class="module-tabs glass">
    <view class="{{active === 'overview' ? 'active' : ''}}" data-tab="overview" bindtap="setTab">总览</view>
    <view class="{{active === 'records' ? 'active' : ''}}" data-tab="records" bindtap="setTab">流水</view>
    <view class="{{active === 'import' ? 'active' : ''}}" data-tab="import" bindtap="setTab">导入导出</view>
  </view>
  <block wx:if="{{active === 'overview'}}">
    <view class="metric-grid">
      <view class="metric glass"><text>收入</text><text class="metric-value">{{summary.incomeText}}</text></view>
      <view class="metric glass"><text>支出</text><text class="metric-value">{{summary.expenseText}}</text></view>
      <view class="metric glass"><text>结余</text><text class="metric-value">{{summary.netText}}</text></view>
      <view class="metric glass"><text>净资产</text><text class="metric-value">{{summary.netWorthText}}</text></view>
    </view>
    <view class="panel"><view class="section-title">最近流水</view><view wx:for="{{recent}}" wx:key="id" class="card-row"><view><view>{{item.category_name || '转账'}}</view><view class="muted">{{item.occurred_on}} {{item.note}}</view></view><text class="{{item.type}}">{{item.amountText}}</text></view></view>
  </block>
  <block wx:elif="{{active === 'records'}}">
    <view class="panel"><view class="section-title">流水</view><view wx:for="{{records}}" wx:key="id" class="card-row"><view><view>{{item.category_name || '转账'}} · {{item.account_name}}</view><view class="muted">{{item.occurred_on}} · {{item.member_name}}</view></view><text class="{{item.type}}">{{item.amountText}}</text></view></view>
  </block>
  <block wx:else>
    <view class="panel"><view class="section-title">导出流水</view><button bindtap="copyExport">复制 CSV</button></view>
    <view class="panel"><view class="section-title">导入 CSV</view><textarea value="{{importText}}" data-field="importText" bindinput="onInput" placeholder="date,type,amount,category,account,member,note"></textarea><button bindtap="importCsv" loading="{{importing}}">导入</button></view>
  </block>
</view>
