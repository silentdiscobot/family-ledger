page {
  min-height: 100vh;
  color: #0f2742;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: linear-gradient(135deg, #f8fdff 0%, #e7f7ff 48%, #ffffff 100%);
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.glass,
.panel {
  border: 1rpx solid rgba(255,255,255,.82);
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.7), rgba(221,246,255,.48));
  box-shadow: 0 24rpx 70rpx rgba(31,112,168,.16);
}

.panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.title {
  margin: 0 0 24rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.section-title {
  margin: 8rpx 0 20rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.eyebrow,
.muted {
  color: #5f7895;
  font-size: 24rpx;
}

input,
textarea,
picker {
  width: 100%;
  min-height: 82rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(125,188,232,.34);
  border-radius: 20rpx;
  background: rgba(255,255,255,.76);
  box-sizing: border-box;
}

textarea {
  min-height: 132rpx;
  padding-top: 20rpx;
}

button {
  min-height: 84rpx;
  border: 0;
  border-radius: 22rpx;
  color: #fff;
  font-weight: 900;
  background: linear-gradient(135deg, #1ba9ec, #55dcc8);
}

.field {
  display: grid;
  gap: 12rpx;
  margin-bottom: 22rpx;
  color: #5f7895;
  font-size: 24rpx;
  font-weight: 800;
}

.card-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(125,188,232,.24);
}

.card-row:last-child {
  border-bottom: 0;
}

.income {
  color: #16a34a;
}

.expense {
  color: #e11d48;
}
